{
  "name": "chromashift",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run check:dist",
    "check:dist": "node scripts/check-dist-assets.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:webgl": "playwright test --project=chromium",
    "test:e2e:webgpu": "playwright test --project=chromium-webgpu",
    "test:e2e:update": "playwright test --update-snapshots",
    "build:wasm": "npm run codegen:band && make -C cpp release",
    "build:wasm:debug": "npm run codegen:band && make -C cpp debug",
    "build:wasm:force": "npm run codegen:band && make -C cpp rebuild",
    "codegen:band": "node scripts/codegen-band.mjs",
    "check:wasm": "make -C cpp check",
    "clean:wasm": "make -C cpp clean",
    "test:cpp": "make -C cpp test"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webxr": "^0.5.24",
    "@vitejs/plugin-react": "^5.0.0",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.0.0",
    "vitest": "^3.2.7"
  }
}
